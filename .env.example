# Copy to .env (which is gitignored) and fill in — or set these in your MCP
# client config's "env" block. NEVER commit real credentials.

# --- Anonymous access (public list archives) -------------------------------
# Anonymous IMAP uses your email address as the "password" field. This is the
# recommended default for public lists; no real secret is involved.
IETF_IMAP_USER=anonymous
IETF_IMAP_EMAIL=you@example.org

# --- Authenticated access (only when anonymous is not possible) -------------
# Use your IETF Datatracker username + password. Prefer ONE of the indirect
# forms below so the secret never sits in plaintext in a config file.
#
#   IETF_IMAP_USER=your-datatracker-username
#
# Option A — resolve from a secret manager at launch (recommended):
#   IETF_IMAP_PASSWORD_CMD=op read "op://Private/IETF Datatracker/password"
#
# Option B — read from a file with restricted permissions (chmod 600):
#   IETF_IMAP_PASSWORD_FILE=~/.config/ietf-imap/datatracker.pw
#
# Option C — plaintext (discouraged; only for throwaway/local testing):
#   IETF_IMAP_PASSWORD=changeme

# --- Tuning ----------------------------------------------------------------
# Minimum seconds between IMAP commands (be kind to shared infrastructure).
IETF_IMAP_MIN_INTERVAL=1.0
# Mailbox prefix for bare list names (imap.ietf.org uses "Shared Folders/").
# IETF_IMAP_MAILBOX_PREFIX=Shared Folders/
